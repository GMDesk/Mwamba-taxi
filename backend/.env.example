# Django Environment Configuration
# Copy this file to .env and fill in the values

# Django
SECRET_KEY=change-me-to-a-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://mwamba:mwamba_secret@localhost:5432/mwamba_taxi

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# SMS / OTP (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Maxicash Payment (legacy)
MAXICASH_MERCHANT_ID=
MAXICASH_MERCHANT_SECRET=
MAXICASH_API_URL=https://api.maxicashapp.com

# PawaPay Mobile Money (Vodacom, Airtel, Orange — RDC)
PAWAPAY_API_TOKEN=
PAWAPAY_WEBHOOK_SECRET=
PAWAPAY_API_URL=https://api.sandbox.pawapay.io

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Google Maps
GOOGLE_MAPS_API_KEY=

# Commission Rate (percentage)
COMMISSION_RATE=15

# Media / Storage
MEDIA_URL=/media/
STATIC_URL=/static/

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
