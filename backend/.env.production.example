# ============================================================
# Mwamba Taxi — Configuration de Production
# Copiez ce fichier en .env.production et remplissez les valeurs
# ============================================================

# Django
SECRET_KEY=changez_ceci_avec_une_cle_aleatoire_de_50_caracteres
DEBUG=False
ALLOWED_HOSTS=mwambataxi.com,www.mwambataxi.com,34.62.184.191,localhost
DJANGO_SETTINGS_MODULE=config.settings

# Base de données PostgreSQL (le service Docker s'appelle "db")
DATABASE_URL=postgres://mwamba:MOT_DE_PASSE_DB@db:5432/mwamba_taxi
DB_PASSWORD=MOT_DE_PASSE_DB

# Redis (le service Docker s'appelle "redis")
REDIS_URL=redis://redis:6379/0

# CORS — domaines autorisés à appeler l'API
CORS_ALLOWED_ORIGINS=https://mwambataxi.com,https://www.mwambataxi.com

# JWT (noms EXACTS attendus par settings.py)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# PawaPay Mobile Money — LIVE (Vodacom, Airtel, Orange — RDC)
# Obtenez votre token sur https://dashboard.pawapay.io
PAWAPAY_API_TOKEN=votre_token_live_pawapay
PAWAPAY_WEBHOOK_SECRET=votre_webhook_secret_pawapay
PAWAPAY_API_URL=https://api.pawapay.io

# Firebase (notifications push)
# Chemin dans le conteneur — monté via volume dans docker-compose
FIREBASE_CREDENTIALS_PATH=/app/firebase-key.json

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# Taux de commission (%)
COMMISSION_RATE=15
cd Mwamba-taxi/backend