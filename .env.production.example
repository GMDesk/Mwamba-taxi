# ============================================================
# Mwamba Taxi — Configuration de Production
# Copiez ce fichier en .env.production et remplissez les valeurs
# ============================================================

# Django
SECRET_KEY=changez_ceci_avec_une_cle_aleatoire_de_50_caracteres
DEBUG=False
ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com
DJANGO_SETTINGS_MODULE=config.settings

# Base de données PostgreSQL (le service Docker s'appelle "db")
DATABASE_URL=postgres://mwamba:MOT_DE_PASSE_DB@db:5432/mwamba_taxi
DB_PASSWORD=MOT_DE_PASSE_DB

# Redis (le service Docker s'appelle "redis")
REDIS_URL=redis://redis:6379/0

# CORS — domaines autorisés à appeler l'API
CORS_ALLOWED_ORIGINS=https://votre-domaine.com

# JWT (durées en minutes / jours)
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Firebase (notifications push)
# Chemin du fichier JSON de clé de service dans le conteneur
FIREBASE_CREDENTIALS_PATH=/app/firebase-key.json

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# Email (facultatif)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre@email.com
EMAIL_HOST_PASSWORD=mot_de_passe_app
DEFAULT_FROM_EMAIL=noreply@votre-domaine.com
